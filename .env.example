# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Supabase project credentials (from your Supabase project settings > API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# A random secret string YOU make up, used to protect the cron endpoint
